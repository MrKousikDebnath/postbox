{
  "name": "postbox",
  "version": "0.1.0",
  "description": "API client + Chrome DevTools network recorder",
  "main": "out/main/index.js",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dist": "electron-vite build && electron-builder --publish never"
  },
  "build": {
    "appId": "com.kousikdebnath.postbox",
    "productName": "PostBox",
    "files": [
      "out/**",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "publish": {
      "provider": "github",
      "owner": "MrKousikDebnath",
      "repo": "postbox"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.3",
    "chrome-remote-interface": "^0.33.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome-remote-interface": "^0.31.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
